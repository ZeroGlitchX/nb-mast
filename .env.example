# NetBox target
NETBOX_URL=http://192.168.65.40:8000

# Primary script auth (recommended: v2 Bearer)
NETBOX_AUTH_SCHEME=Bearer
NETBOX_API_TOKEN=<FULL_V2_TOKEN>

# Explicit token references
NETBOX_API_TOKEN_V1=<V1_TOKEN>
NETBOX_API_TOKEN_V2_PREFIX=nbt_BiFEaPwnLM5r
NETBOX_API_TOKEN_V2_SUFFIX=<V2_TOKEN_SUFFIX>
NETBOX_API_TOKEN_V2=nbt_BiFEaPwnLM5r.<V2_TOKEN_SUFFIX>

# Fallback script auth (example: v1 Token)
NETBOX_AUTH_SCHEME_FALLBACK=Token
NETBOX_API_TOKEN_FALLBACK=<V1_TOKEN>

# Optional import helper
NETBOX_DEFAULT_USER_PASSWORD=<DEFAULT_USER_PASSWORD>
