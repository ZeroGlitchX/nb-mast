# Load environment variables from .env
set -a
source .env
set +a

# Primary auth preflight (v2 Bearer)
python3 netbox_import.py --input-dir exports --preflight

# Fallback auth preflight (v1 Token)
# NETBOX_AUTH_SCHEME="${NETBOX_AUTH_SCHEME_FALLBACK}" \
# NETBOX_API_TOKEN="${NETBOX_API_TOKEN_FALLBACK}" \
# python3 netbox_import.py --input-dir exports --preflight

# Test v2 Bearer token (expected HTTP 200 on success)
curl -sS -o /tmp/netbox_status_v2.json -w "HTTP:%{http_code}\n" \
  -X GET \
  -H "Authorization: Bearer ${NETBOX_API_TOKEN_V2}" \
  -H "Content-Type: application/json" \
  -H "Accept: application/json; indent=4" \
  "${NETBOX_URL}/api/status/"
cat /tmp/netbox_status_v2.json

# Test v1 Token fallback (expected HTTP 200 on success)
curl -sS -o /tmp/netbox_status_v1.json -w "HTTP:%{http_code}\n" \
  -X GET \
  -H "Authorization: Token ${NETBOX_API_TOKEN_V1}" \
  -H "Content-Type: application/json" \
  -H "Accept: application/json; indent=4" \
  "${NETBOX_URL}/api/status/"
cat /tmp/netbox_status_v1.json
